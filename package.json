{
  "name": "agentic",
  "version": "0.1.0",
  "description": "Manage cross-platform AI agent configuration from a single .agentic/ directory",
  "type": "module",
  "files": [
    "dist/"
  ],
  "bin": {
    "agentic": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "gray-matter": "^4.0.3",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
